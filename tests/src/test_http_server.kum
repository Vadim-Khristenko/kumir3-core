использовать Сокеты

алг ОбработатьПривет(запрос: HTTPЗапрос): HTTPОтвет
нач
    знач := HTTPОтвет.Текст("Привет, мир!")
кон

алг ОбработатьПользователя(запрос: HTTPЗапрос): HTTPОтвет
нач
    id := запрос.Параметр("id")
    знач := HTTPОтвет.JSON("{\"user\": \"" + id + "\"}")
кон

алг
нач
    сервер := HTTPСервер.Новый(8080)
