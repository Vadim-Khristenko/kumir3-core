| ============================================
|    Тест пользовательских библиотек КуМир
| ============================================

| Способ 2: Определение inline библиотеки (модуля)
модуль МояБиблиотека
    | Вычисляет квадрат числа
    алг цел квадрат(арг цел x)
    нач
        знач := x * x
    кон
    
    | Вычисляет куб числа
    алг цел куб(арг цел x)
    нач
        знач := x * x * x
    кон
    
    | Константа PI
    алг вещ ПИ
    нач
        знач := 3.14159265
    кон
кон

| ============================================
|             ОСНОВНАЯ ПРОГРАММА
| ============================================

алг
нач
    вывод "=== Тест пользовательских библиотек ==="
    нс
    
    | Тест inline модуля
    цел результат
    результат := МояБиблиотека.квадрат(5)
    вывод "Квадрат 5 = ", результат
    нс
    
    результат := МояБиблиотека.куб(3)
    вывод "Куб 3 = ", результат
    нс
    
    вещ пи
    пи := МояБиблиотека.ПИ()
    вывод "ПИ = ", пи
    нс
    
    | Без модуля - простые алгоритмы
    вывод "Факториал 5 = ", факториал(5)
    нс
    вывод "Фибоначчи 10 = ", фибоначчи(10)
    нс
    
    вывод "Тест завершён!"
кон

| Вспомогательные алгоритмы без модуля
алг цел факториал(арг цел n)
нач
    если n <= 1 то
        знач := 1
    иначе
        знач := n * факториал(n - 1)
    всё
кон

алг цел фибоначчи(арг цел n)
нач
    если n <= 1 то
        знач := n
    иначе
        знач := фибоначчи(n - 1) + фибоначчи(n - 2)
    всё
кон
